---
import type { Plan } from '../../content/_types';
import { formatARS } from '../../lib/precios';

interface Props {
  plan: Plan;
}

const { plan } = Astro.props;
// Duración por defecto: la primera (anual en suscripciones, única en finitos).
const d = plan.duraciones[0];
const colorHex = plan.color_hex;
const tipoLabel = plan.tipo === 'finito' ? 'Tratamiento' : 'Suscripción';
---
<article
  data-plan-card
  data-plan-slug={plan.slug}
  class={`relative flex flex-col w-full h-full bg-violet-mid rounded-card p-5 text-cream ${plan.destacado ? 'border-2 border-accent-gold' : 'border border-white/15'}`}
>
  {plan.destacado && (
    <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-accent-gold text-accent-gold-dark px-3 py-1 rounded text-[10px] font-bold tracking-wider whitespace-nowrap">
      ★ RECOMENDADO
    </div>
  )}
  <div class="px-3 py-1 rounded text-[10px] font-bold tracking-widest inline-block self-start" style={`background-color: ${colorHex}; color: #1A1033;`}>
    {plan.nombre}
  </div>
  <p class="text-[11px] opacity-60 mt-2 uppercase tracking-wider">{tipoLabel} · {plan.subtitulo}</p>
  <p class="text-sm font-medium mt-1 leading-snug">{plan.hook}</p>
  <p class="text-xs opacity-70 mt-2 leading-relaxed">{plan.beneficios_destacados.join(' · ')}</p>

  <div class="mt-auto pt-5">
    <div class="flex items-baseline gap-2">
      <span class="text-[9px] opacity-55 tracking-wider uppercase" data-plan-periodo>{d.label}</span>
      {d.ahorro_label && (
        <span class="text-[10px] font-semibold px-1.5 py-0.5 rounded" data-plan-ahorro style={`color: ${colorHex}; background-color: ${colorHex}1A;`}>{d.ahorro_label}</span>
      )}
    </div>
    <div class="text-2xl font-bold mt-1" data-plan-total style={`color: ${colorHex};`}>{formatARS(d.total)}</div>
    <div class="text-[11px] opacity-60" data-plan-equiv>≈ {formatARS(d.equiv_valor)} {d.equiv_label}</div>
  </div>

  <a
    href={`/planes/${plan.slug}`}
    class="mt-4 block text-center text-xs font-bold py-2.5 rounded-pill"
    style={`background-color: ${colorHex}; color: #1A1033;`}
  >
    Ver plan →
  </a>
</article>
