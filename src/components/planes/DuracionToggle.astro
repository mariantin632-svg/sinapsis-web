---
const opciones = [
  { periodo: 'anual', short: 'Anual · hasta 27% off' },
  { periodo: 'semestral', short: 'Semestral' },
];
---
<div class="inline-flex gap-1 bg-white/8 rounded-card p-1 text-xs">
  {opciones.map((op) => (
    <button
      data-duracion-btn
      data-periodo={op.periodo}
      class={`px-3 py-1.5 rounded ${op.periodo === 'anual' ? 'bg-cream text-violet-deep font-bold' : 'text-cream/60 hover:text-cream'}`}
    >
      {op.short}
    </button>
  ))}
</div>

<script>
  import planesData from '../../content/planes.json';
  const planes = planesData as any[];

  function formatARS(amount: number): string {
    return new Intl.NumberFormat('es-AR', {
      style: 'currency',
      currency: 'ARS',
      minimumFractionDigits: 0,
      maximumFractionDigits: 0,
    }).format(amount).replace(/\s/g, '');
  }

  function updatePrices(periodo: string) {
    const cards = document.querySelectorAll<HTMLElement>('[data-plan-card]');
    cards.forEach((card) => {
      const plan = planes.find((p) => p.slug === card.dataset.planSlug);
      if (!plan) return;
      // Si el plan no tiene el período elegido (Osteo solo anual, Kine 10 finito),
      // se queda con su duración por defecto.
      const d = plan.duraciones.find((x: any) => x.periodo === periodo) ?? plan.duraciones[0];

      const totalEl = card.querySelector<HTMLElement>('[data-plan-total]');
      if (totalEl) totalEl.textContent = formatARS(d.total);

      const equivEl = card.querySelector<HTMLElement>('[data-plan-equiv]');
      if (equivEl) equivEl.textContent = `≈ ${formatARS(d.equiv_valor)} ${d.equiv_label}`;

      const periodoEl = card.querySelector<HTMLElement>('[data-plan-periodo]');
      if (periodoEl) periodoEl.textContent = d.label;

      const ahorroEl = card.querySelector<HTMLElement>('[data-plan-ahorro]');
      if (ahorroEl) {
        if (d.ahorro_label) {
          ahorroEl.textContent = d.ahorro_label;
          ahorroEl.style.display = '';
        } else {
          ahorroEl.style.display = 'none';
        }
      }
    });
  }

  document.querySelectorAll<HTMLButtonElement>('[data-duracion-btn]').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll<HTMLElement>('[data-duracion-btn]').forEach((b) => {
        b.classList.remove('bg-cream', 'text-violet-deep', 'font-bold');
        b.classList.add('text-cream/60');
      });
      btn.classList.remove('text-cream/60');
      btn.classList.add('bg-cream', 'text-violet-deep', 'font-bold');
      updatePrices(btn.dataset.periodo as string);
    });
  });
</script>
