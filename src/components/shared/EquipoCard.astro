---
import { existsSync } from 'node:fs';
import path from 'node:path';
import type { Profesional } from '../../content/_types';
import sitio from '../../content/sitio.json';
import { buildWhatsAppUrl } from '../../lib/whatsapp';

interface Props {
  profesional: Profesional;
}

const { profesional } = Astro.props;

const iniciales = `${profesional.nombre.charAt(0)}${profesional.apellido.charAt(0)}`;
// Si no hay foto en public/ quedan las iniciales (Dante va sin foto a propósito)
// y evitamos un 404 en consola.
const fotoExiste = existsSync(path.join(process.cwd(), 'public', profesional.foto));
const turnitoUrl = profesional.turnito || sitio.turnito?.hub || '#';
const whatsappUrl = buildWhatsAppUrl({
  phone: sitio.contacto.whatsapp,
  text: `Hola! Quería consultar un turno con ${profesional.nombre} ${profesional.apellido}.`,
});
const chips = [...(profesional.modalidades ?? [])];
if (profesional.destacado_label) chips.push(profesional.destacado_label);
---
<div class="bg-white rounded-card p-5 shadow-card hover:shadow-card-hover transition flex flex-col">
  <div class="flex gap-3 items-center">
    <div class="relative w-14 h-14 flex-shrink-0">
      <div class="absolute inset-0 rounded-full bg-gradient-to-br from-sinapsis-purple to-accent-mint flex items-center justify-center text-white font-bold">
        {iniciales}
      </div>
      {fotoExiste && (
        <img
          src={profesional.foto}
          alt={`${profesional.nombre} ${profesional.apellido}`}
          class="absolute inset-0 w-full h-full rounded-full object-cover ring-2 ring-accent-mint"
        />
      )}
    </div>
    <div class="min-w-0">
      <div class="font-bold text-violet-deep leading-tight">{profesional.nombre} {profesional.apellido}</div>
      <div class="text-xs text-sinapsis-purple font-semibold mt-0.5">{profesional.especialidades.join(' · ')}</div>
    </div>
  </div>

  {chips.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-3">
      {chips.map((c) => (
        <span class="text-[10px] bg-cream text-sinapsis-purple px-2 py-0.5 rounded-pill font-semibold">{c}</span>
      ))}
    </div>
  )}

  <p class="text-xs text-gray-600 mt-3 leading-relaxed flex-1">{profesional.bio_corta}</p>

  <div class="flex gap-2 mt-4">
    <a
      href={turnitoUrl}
      target="_blank"
      rel="noopener"
      class="flex-1 text-center bg-accent-mint text-accent-mint-dark text-xs font-bold py-2 rounded-pill hover:opacity-90 transition"
    >
      Reservar turno
    </a>
    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener"
      class="flex-1 text-center border border-sinapsis-purple text-sinapsis-purple text-xs font-bold py-2 rounded-pill hover:bg-sinapsis-purple hover:text-white transition"
    >
      Consultar
    </a>
  </div>
</div>
