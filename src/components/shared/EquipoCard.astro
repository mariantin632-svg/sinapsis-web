---
import type { Profesional } from '../../content/_types';

interface Props {
  profesional: Profesional;
  variant?: 'compact' | 'full';
}

const { profesional, variant = 'compact' } = Astro.props;
---
<div class="bg-cream-bg rounded-card p-4 flex gap-3 items-center hover:shadow-card-hover transition">
  <div class="w-16 h-16 rounded-full bg-gray-300 flex-shrink-0 overflow-hidden">
    <img
      src={profesional.foto}
      alt={`${profesional.nombre} ${profesional.apellido}`}
      class="w-full h-full object-cover"
      onerror="this.style.display='none'"
    />
  </div>
  <div class="flex-1 min-w-0">
    <div class="font-semibold text-violet-deep text-sm">{profesional.nombre} {profesional.apellido}</div>
    <div class="text-xs text-gray-600">{profesional.especialidades.join(' · ')}</div>
    {variant === 'full' && (
      <div class="text-xs text-gray-500 mt-1">Matrícula: {profesional.matricula}</div>
    )}
    <a href={`/equipo#${profesional.slug}`} class="text-xs text-accent-mint hover:underline mt-1 inline-block">Ver perfil →</a>
  </div>
</div>
