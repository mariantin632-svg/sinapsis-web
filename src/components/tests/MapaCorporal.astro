---
import sitio from '../../content/sitio.json';
const wa = `https://wa.me/${sitio.contacto.whatsapp}`;

// Zonas: posición del hotspot (viewBox 0 0 200 460) + contenido orientativo.
const zonas = [
  { id: 'cuello', x: 100, y: 64, label: 'Cuello / cervical',
    texto: 'Tensión y dolor cervical, muy común por pantallas, malas posturas y estrés. Trabajamos movilidad, descompresión y pautas posturales.',
    reco: 'Osteopatía o Kinesiología' },
  { id: 'hombro', x: 60, y: 92, label: 'Hombro',
    texto: 'Dolor, pinzamiento o pérdida de movilidad del hombro. Evaluamos manguito rotador y patrón de movimiento.',
    reco: 'Kinesiología + evaluación funcional' },
  { id: 'codo', x: 48, y: 150, label: 'Codo / muñeca',
    texto: 'Codo de tenista, tendinitis o molestias por sobreuso. Recuperamos fuerza y descargamos la zona.',
    reco: 'Kinesiología (Kine 10)' },
  { id: 'lumbar', x: 100, y: 150, label: 'Espalda / lumbar',
    texto: 'El dolor lumbar mejora con movimiento, no con reposo prolongado. Rehabilitación activa + ejercicios para casa.',
    reco: 'PREMIER KINE o Kine 10' },
  { id: 'cadera', x: 100, y: 206, label: 'Cadera / pelvis',
    texto: 'Molestias de cadera, pubis o pelvis. Liberamos restricciones y reequilibramos cargas.',
    reco: 'Osteopatía + Kinesiología' },
  { id: 'rodilla', x: 86, y: 300, label: 'Rodilla',
    texto: 'Dolor de rodilla (corredores, fútbol, gimnasio). Evaluamos pisada, fuerza y técnica de movimiento.',
    reco: 'PERFORMANCE o Kine deportiva' },
  { id: 'tobillo', x: 86, y: 392, label: 'Tobillo / pie',
    texto: 'Esguinces, inestabilidad y readaptación deportiva. Volvemos a la actividad de forma progresiva y segura.',
    reco: 'Kine 10 o Kine deportiva' },
];
---
<div class="grid md:grid-cols-2 gap-6 items-center" data-mapa>
  <!-- Figura + hotspots -->
  <div class="flex justify-center">
    <svg viewBox="0 0 200 460" class="w-48 md:w-56" role="img" aria-label="Silueta del cuerpo">
      <g fill="#2D1B5E" stroke="#5DCAA5" stroke-width="1.5" opacity="0.95">
        <circle cx="100" cy="36" r="26" />
        <rect x="66" y="70" width="68" height="128" rx="28" />
        <rect x="44" y="84" width="18" height="120" rx="9" />
        <rect x="138" y="84" width="18" height="120" rx="9" />
        <rect x="70" y="188" width="60" height="44" rx="20" />
        <rect x="78" y="224" width="20" height="184" rx="10" />
        <rect x="102" y="224" width="20" height="184" rx="10" />
        <ellipse cx="86" cy="414" rx="16" ry="9" />
        <ellipse cx="114" cy="414" rx="16" ry="9" />
      </g>
      {zonas.map((z) => (
        <g class="hotspot cursor-pointer" data-zona={z.id} tabindex="0" role="button" aria-label={z.label}>
          <circle cx={z.x} cy={z.y} r="14" fill="#5DCAA5" opacity="0.18" class="pulse" />
          <circle cx={z.x} cy={z.y} r="7" fill="#5DCAA5" stroke="#F5F2FF" stroke-width="1.5" />
        </g>
      ))}
    </svg>
  </div>

  <!-- Panel de resultado -->
  <div class="bg-violet-mid rounded-card p-5 min-h-52 flex flex-col justify-center" data-panel>
    <div data-panel-empty class="text-center text-cream/60 text-sm">
      <div class="text-3xl mb-2">👆</div>
      Tocá la zona que te molesta en la figura para ver qué te conviene.
    </div>
    <div data-panel-content class="hidden">
      <div class="text-xs uppercase tracking-widest text-accent-mint" data-zona-label></div>
      <p class="text-sm text-cream/85 mt-2 leading-relaxed" data-zona-texto></p>
      <div class="mt-3 text-xs text-cream/60">Te conviene:</div>
      <div class="text-sm font-semibold text-cream" data-zona-reco></div>
      <a data-zona-cta target="_blank" rel="noopener"
        class="mt-4 inline-block bg-accent-mint text-accent-mint-dark px-4 py-2 rounded-pill text-xs font-bold hover:opacity-90 transition">
        📱 Consultar por esta zona
      </a>
    </div>
  </div>
</div>

<p class="text-[11px] text-cream/45 mt-4 text-center max-w-xl mx-auto">
  Información orientativa, no reemplaza una consulta profesional. Ante dolor persistente, agendá una evaluación.
</p>

<script define:vars={{ zonas, wa }}>
  document.querySelectorAll('[data-mapa]').forEach((root) => {
    const data = Object.fromEntries(zonas.map((z) => [z.id, z]));
    const panelEmpty = root.querySelector('[data-panel-empty]');
    const panelContent = root.querySelector('[data-panel-content]');
    const elLabel = root.querySelector('[data-zona-label]');
    const elTexto = root.querySelector('[data-zona-texto]');
    const elReco = root.querySelector('[data-zona-reco]');
    const elCta = root.querySelector('[data-zona-cta]');

    function select(id) {
      const z = data[id];
      if (!z) return;
      root.querySelectorAll('.hotspot').forEach((h) =>
        h.classList.toggle('activa', h.dataset.zona === id));
      elLabel.textContent = z.label;
      elTexto.textContent = z.texto;
      elReco.textContent = z.reco;
      elCta.href = `${wa}?text=${encodeURIComponent(`Hola! Me molesta la zona: ${z.label}. Quería consultar.`)}`;
      panelEmpty.classList.add('hidden');
      panelContent.classList.remove('hidden');
    }

    root.querySelectorAll('.hotspot').forEach((h) => {
      h.addEventListener('click', () => select(h.dataset.zona));
      h.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); select(h.dataset.zona); }
      });
    });
  });
</script>

<style>
  .pulse { animation: pulse 2s ease-in-out infinite; transform-origin: center; transform-box: fill-box; }
  @keyframes pulse { 0%, 100% { opacity: 0.12; } 50% { opacity: 0.35; } }
  .hotspot:hover circle, .hotspot.activa circle { fill: #F4D03F; }
  .hotspot.activa .pulse { fill: #F4D03F; }
  @media (prefers-reduced-motion: reduce) { .pulse { animation: none; } }
</style>
