---
import sitio from '../../content/sitio.json';
import chat from '../../content/chat.json';
import { buildWhatsAppUrl } from '../../lib/whatsapp';

const turnitoUrl = sitio.turnito?.hub ?? '#';
const whatsappUrl = buildWhatsAppUrl({
  phone: sitio.contacto.whatsapp,
  text: 'Hola! Llegué desde la web y quería hacer una consulta.',
});

// Resuelve la acción de cada CTA a un href + si es externo.
function resolveCta(action: string): { href: string; external: boolean } {
  if (action === 'turnito') return { href: turnitoUrl, external: true };
  if (action === 'whatsapp') return { href: whatsappUrl, external: true };
  return { href: action, external: false }; // ruta interna (ej. /planes)
}

const items = chat.items.map((it) => ({
  q: it.q,
  a: it.a,
  cta: it.cta ? { label: it.cta.label, ...resolveCta(it.cta.action) } : null,
}));
---
<!-- Launcher -->
<button
  type="button"
  data-chat-toggle
  aria-label="Abrir chat de Sinapsis"
  aria-expanded="false"
  class="fixed bottom-6 right-6 z-50 bg-sinapsis-purple hover:opacity-90 text-white w-14 h-14 rounded-full flex items-center justify-center shadow-lg text-2xl transition"
>
  <span data-chat-icon>💬</span>
</button>

<!-- Panel -->
<div
  data-chat-panel
  class="hidden fixed bottom-24 right-6 z-50 w-[22rem] max-w-[calc(100vw-2rem)] max-h-[72vh] bg-white rounded-2xl shadow-2xl border border-gray-200 flex flex-col overflow-hidden"
>
  <div class="bg-sinapsis-purple text-white px-4 py-3 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <div class="w-9 h-9 rounded-full bg-white/15 flex items-center justify-center text-lg">💬</div>
      <div class="leading-tight">
        <div class="font-bold text-sm">Sinapsis</div>
        <div class="text-[11px] text-white/70">Asistente · respuestas al toque</div>
      </div>
    </div>
    <button type="button" data-chat-close aria-label="Cerrar chat" class="text-white/80 hover:text-white text-xl leading-none">×</button>
  </div>

  <div data-chat-log class="flex-1 overflow-y-auto p-3 space-y-2 bg-cream-bg flex flex-col"></div>

  <div data-chat-replies class="border-t border-gray-200 p-3 bg-white flex flex-wrap gap-2 max-h-[40%] overflow-y-auto">
    {items.map((it, i) => (
      <button
        type="button"
        data-q={i}
        class="text-xs text-violet-deep bg-cream-bg hover:bg-violet-deep/5 border border-gray-200 rounded-pill px-3 py-1.5 transition text-left"
      >{it.q}</button>
    ))}
    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener"
      class="w-full text-center text-xs font-bold text-white bg-[#25D366] hover:bg-[#1ebd5b] rounded-pill px-3 py-2 transition"
    >💬 Hablar con una persona (WhatsApp)</a>
  </div>
</div>

<script define:vars={{ items, saludo: chat.saludo }}>
  document.querySelectorAll('[data-chat-toggle]').forEach((toggle) => {
    const root = document;
    const panel = root.querySelector('[data-chat-panel]');
    const log = root.querySelector('[data-chat-log]');
    const icon = toggle.querySelector('[data-chat-icon]');
    const closeBtn = root.querySelector('[data-chat-close]');
    let greeted = false;

    const esc = (s) =>
      String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));

    function addBot(html) {
      const el = document.createElement('div');
      el.className = 'self-start max-w-[85%] bg-white border border-gray-200 rounded-2xl rounded-tl-sm px-3 py-2 text-sm text-gray-700 shadow-sm';
      el.innerHTML = html;
      log.appendChild(el);
      log.scrollTop = log.scrollHeight;
    }
    function addUser(text) {
      const el = document.createElement('div');
      el.className = 'self-end max-w-[85%] bg-sinapsis-purple text-white rounded-2xl rounded-tr-sm px-3 py-2 text-sm';
      el.textContent = text;
      log.appendChild(el);
      log.scrollTop = log.scrollHeight;
    }

    function open() {
      panel.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      if (icon) icon.textContent = '×';
      if (!greeted) { addBot(esc(saludo)); greeted = true; }
    }
    function close() {
      panel.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      if (icon) icon.textContent = '💬';
    }

    toggle.addEventListener('click', () =>
      panel.classList.contains('hidden') ? open() : close());
    closeBtn?.addEventListener('click', close);

    root.querySelectorAll('[data-q]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const it = items[Number(btn.getAttribute('data-q'))];
        if (!it) return;
        addUser(it.q);
        let html = esc(it.a);
        if (it.cta) {
          const target = it.cta.external ? ' target="_blank" rel="noopener"' : '';
          html += `<a href="${it.cta.href}"${target} class="mt-2 inline-block text-xs font-bold text-white bg-sinapsis-purple rounded-pill px-3 py-1.5 hover:opacity-90 transition">${esc(it.cta.label)} →</a>`;
        }
        addBot(html);
      });
    });
  });
</script>
