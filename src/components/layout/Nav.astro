---
import sitio from '../../content/sitio.json';
import { buildWhatsAppUrl } from '../../lib/whatsapp';

const links = [
  { href: '/', label: 'Inicio' },
  { href: '/servicios-sueltos', label: 'Servicios' },
  { href: '/equipo', label: 'Equipo' },
  { href: '/planes', label: 'Planes' },
  { href: '/obras-sociales', label: 'Obras sociales' },
  { href: '/faq', label: 'FAQ' },
];

const whatsappUrl = buildWhatsAppUrl({
  phone: sitio.contacto.whatsapp,
  text: 'Hola! Llegué desde la web y quería consultar.',
});
const turnitoUrl = sitio.turnito?.hub ?? '#';
const instagramUrl = sitio.contacto.instagram_url;
---
<nav class="sticky top-0 z-50 bg-violet-mid border-b border-white/10">
  <div class="max-w-7xl mx-auto px-6 py-2.5 flex items-center justify-between gap-4">
    <a href="/" class="flex items-center" aria-label="Sinapsis — inicio">
      <img
        src="/logo-sinapsis-nav.png"
        alt="Sinapsis — Centro de Rehabilitación Traumatológica y Deportiva"
        class="h-9 md:h-10 w-auto"
        width="287"
        height="48"
      />
    </a>

    <div class="hidden md:flex gap-5 text-sm text-cream/80">
      {links.map((l) => (
        <a href={l.href} class="hover:text-cream transition">{l.label}</a>
      ))}
    </div>

    <div class="flex items-center gap-2">
      {instagramUrl && (
        <a
          href={instagramUrl}
          target="_blank"
          rel="noopener"
          aria-label="Instagram de Sinapsis"
          class="hidden sm:inline-flex w-8 h-8 items-center justify-center rounded-full border border-white/20 text-cream/80 hover:text-cream hover:border-white/40 transition"
        >
          <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="2" width="20" height="20" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
          </svg>
        </a>
      )}
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener"
        aria-label="WhatsApp de Sinapsis"
        class="hidden sm:inline-flex items-center justify-center px-3 py-1.5 rounded-pill text-xs font-semibold border border-white/25 text-cream/90 hover:bg-white/10 transition"
      >
        WhatsApp
      </a>
      <a
        href={turnitoUrl}
        target="_blank"
        rel="noopener"
        class="bg-accent-mint text-accent-mint-dark px-4 py-1.5 rounded-pill text-xs font-bold hover:opacity-90 transition whitespace-nowrap"
      >
        Agendar turno
      </a>
    </div>
  </div>

  <details class="md:hidden border-t border-white/10">
    <summary class="text-cream/80 text-sm px-6 py-2 cursor-pointer">Menú</summary>
    <div class="flex flex-col bg-violet-deep">
      {links.map((l) => (
        <a href={l.href} class="text-cream/80 px-6 py-3 border-t border-white/10 text-sm">{l.label}</a>
      ))}
      <a href={whatsappUrl} target="_blank" rel="noopener" class="text-cream/80 px-6 py-3 border-t border-white/10 text-sm">WhatsApp</a>
      {instagramUrl && (
        <a href={instagramUrl} target="_blank" rel="noopener" class="text-cream/80 px-6 py-3 border-t border-white/10 text-sm">Instagram</a>
      )}
    </div>
  </details>
</nav>
