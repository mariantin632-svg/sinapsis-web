---
import sitio from '../../content/sitio.json';
import { buildWhatsAppUrl } from '../../lib/whatsapp';

const links = [
  { href: '/', label: 'Inicio' },
  { href: '/servicios-sueltos', label: 'Servicios' },
  { href: '/equipo', label: 'Equipo' },
  { href: '/planes', label: 'Planes' },
  { href: '/obras-sociales', label: 'Obras sociales' },
  { href: '/faq', label: 'FAQ' },
];

const whatsappUrl = buildWhatsAppUrl({
  phone: sitio.contacto.whatsapp,
  text: 'Hola! Llegué desde la web y quería consultar.',
});
const turnitoUrl = sitio.turnito?.hub ?? '#';
const instagramUrl = sitio.contacto.instagram_url;
---
<nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between gap-4">
    <a href="/" class="flex items-center" aria-label="Sinapsis — inicio">
      <img
        src="/logo-sinapsis.jpg"
        alt="Sinapsis — Centro de Rehabilitación Traumatológica y Deportiva"
        class="h-8 md:h-9 w-auto rounded-md"
        width="240"
        height="36"
      />
    </a>

    <div class="hidden md:flex gap-5 text-sm text-gray-600">
      {links.map((l) => (
        <a href={l.href} class="hover:text-violet-deep transition">{l.label}</a>
      ))}
    </div>

    <div class="flex items-center gap-2">
      {instagramUrl && (
        <a
          href={instagramUrl}
          target="_blank"
          rel="noopener"
          aria-label="Instagram de Sinapsis"
          class="hidden sm:inline-flex w-8 h-8 items-center justify-center rounded-full border border-gray-300 text-gray-500 hover:text-violet-deep hover:border-gray-400 transition"
        >
          <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="2" width="20" height="20" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
          </svg>
        </a>
      )}
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener"
        aria-label="WhatsApp de Sinapsis"
        class="hidden sm:inline-flex items-center justify-center px-3 py-1.5 rounded-pill text-xs font-semibold border border-gray-300 text-violet-deep hover:bg-gray-50 transition"
      >
        WhatsApp
      </a>
      <a
        href={turnitoUrl}
        target="_blank"
        rel="noopener"
        class="bg-sinapsis-purple text-white px-4 py-1.5 rounded-pill text-xs font-bold hover:opacity-90 transition whitespace-nowrap"
      >
        Agendar turno
      </a>
    </div>
  </div>

  <details class="md:hidden border-t border-gray-200">
    <summary class="text-gray-600 text-sm px-6 py-2 cursor-pointer">Menú</summary>
    <div class="flex flex-col bg-cream-bg">
      {links.map((l) => (
        <a href={l.href} class="text-gray-700 px-6 py-3 border-t border-gray-200 text-sm">{l.label}</a>
      ))}
      <a href={whatsappUrl} target="_blank" rel="noopener" class="text-gray-700 px-6 py-3 border-t border-gray-200 text-sm">WhatsApp</a>
      {instagramUrl && (
        <a href={instagramUrl} target="_blank" rel="noopener" class="text-gray-700 px-6 py-3 border-t border-gray-200 text-sm">Instagram</a>
      )}
    </div>
  </details>
</nav>
