---
import sitio from '../../content/sitio.json';
import planes from '../../content/planes.json';
import { buildWhatsAppUrl } from '../../lib/whatsapp';

const whatsappUrl = buildWhatsAppUrl({ phone: sitio.contacto.whatsapp });
const year = new Date().getFullYear();
---
<footer class="bg-cream-bg text-gray-600 px-6 py-10 border-t border-gray-200">
  <div class="max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 text-sm">
    <div>
      <div class="text-violet-deep font-bold tracking-widest mb-3">SINAPSIS</div>
      <p class="text-gray-500 text-xs leading-relaxed">{sitio.tagline}</p>
      <p class="text-gray-500 text-xs mt-3">{sitio.direccion.calle}<br />{sitio.direccion.ciudad}</p>
    </div>

    <div>
      <div class="text-violet-deep font-semibold mb-3 text-xs uppercase tracking-wider">Planes</div>
      <ul class="space-y-1.5 text-xs">
        {planes.map((p) => (
          <li><a href={`/planes/${p.slug}`} class="hover:text-violet-deep transition">{p.nombre}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <div class="text-violet-deep font-semibold mb-3 text-xs uppercase tracking-wider">Servicios</div>
      <ul class="space-y-1.5 text-xs">
        <li><a href="/servicios-sueltos" class="hover:text-violet-deep transition">Sesiones sueltas</a></li>
        <li><a href="/equipo" class="hover:text-violet-deep transition">Equipo</a></li>
        <li><a href="/obras-sociales" class="hover:text-violet-deep transition">Obras sociales</a></li>
        <li><a href="/faq" class="hover:text-violet-deep transition">Preguntas frecuentes</a></li>
      </ul>
    </div>

    <div>
      <div class="text-violet-deep font-semibold mb-3 text-xs uppercase tracking-wider">Contacto</div>
      <ul class="space-y-1.5 text-xs">
        {sitio.turnito?.hub && (
          <li><a href={sitio.turnito.hub} target="_blank" rel="noopener" class="text-sinapsis-purple font-semibold hover:opacity-80 transition">Agendar turno</a></li>
        )}
        <li><a href={whatsappUrl} target="_blank" rel="noopener" class="hover:text-violet-deep transition">WhatsApp</a></li>
        {(sitio.contacto.instagram_url || sitio.contacto.instagram) && (
          <li><a href={sitio.contacto.instagram_url ?? `https://instagram.com/${sitio.contacto.instagram?.replace('@', '')}`} target="_blank" rel="noopener" class="hover:text-violet-deep transition">Instagram</a></li>
        )}
        <li><a href="/contacto" class="hover:text-violet-deep transition">Cómo llegar</a></li>
      </ul>
    </div>
  </div>

  <div class="max-w-7xl mx-auto mt-8 pt-6 border-t border-gray-200 text-center text-xs text-gray-400">
    © {year} Sinapsis · Todos los derechos reservados
  </div>
</footer>
