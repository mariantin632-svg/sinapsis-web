---
// PLACEHOLDER: pedir a Martín 4-8 fotos del centro y reemplazar paths
const fotos = [
  { src: '/galeria/foto-1.jpg', alt: 'Sala de tratamiento' },
  { src: '/galeria/foto-2.jpg', alt: 'Recepción' },
  { src: '/galeria/foto-3.jpg', alt: 'Equipamiento' },
  { src: '/galeria/foto-4.jpg', alt: 'Sesión en curso' },
];
---
<section class="bg-white px-6 py-12 md:py-16">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-8">
      <div class="text-xs text-gray-500 uppercase tracking-widest">El centro por dentro</div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
      {fotos.map((f) => (
        <div class="aspect-square bg-gray-200 rounded overflow-hidden">
          <img src={f.src} alt={f.alt} class="w-full h-full object-cover" onerror="this.style.display='none'" />
        </div>
      ))}
    </div>
  </div>
</section>
