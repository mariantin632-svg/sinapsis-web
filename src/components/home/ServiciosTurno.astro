---
import serviciosData from '../../content/servicios-sueltos.json';
import type { ServicioSuelto } from '../../content/_types';
import { formatARS } from '../../lib/precios';
import Icon from '../shared/Icon.astro';

const servicios = serviciosData as ServicioSuelto[];

const iconos: Record<string, string> = {
  kinesiologia: 'person-arms-up',
  osteopatia: 'hand-index-thumb',
  'consulta-traumatologica': 'clipboard2-pulse',
  'consulta-nutricional': 'egg-fried',
  domicilio: 'house-heart',
};

const modalidadLabel: Record<string, string> = {
  presencial: 'Presencial',
  online: 'Online',
  domicilio: 'A domicilio',
};
---
<section id="servicios" class="max-w-[1200px] mx-auto px-6 pt-24 pb-10">
  <div class="flex flex-wrap items-end justify-between gap-5 mb-11">
    <div class="max-w-[620px]">
      <p class="m-0 mb-2.5 text-xs font-semibold tracking-[1.5px] uppercase text-sn-sage-dark">Sesiones y consultas</p>
      <h2 class="m-0 font-display font-semibold text-[clamp(1.9rem,4vw,2.6rem)] leading-[1.12] tracking-[-0.02em] text-sn-violet">Elegí el servicio que buscás y agendá online en segundos.</h2>
    </div>
    <a href="/servicios-sueltos" class="inline-flex items-center gap-2 text-sm font-semibold text-sn-violet hover:text-sn-violet-light transition whitespace-nowrap">Ver todos los servicios <span class="text-base">→</span></a>
  </div>
  <div class="grid grid-cols-[repeat(auto-fill,minmax(270px,1fr))] gap-5">
    {servicios.map((s) => (
      <div class="bg-white rounded-2xl p-6 shadow-[0_2px_8px_rgba(48,22,109,0.08)] border border-gray-100 flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_32px_rgba(48,22,109,0.16)]">
        <span class="w-[46px] h-[46px] rounded-xl bg-gradient-to-br from-sn-violet to-sn-violet-light flex items-center justify-center text-white text-[21px] mb-4">
          <Icon name={iconos[s.slug] ?? 'plus-lg'} />
        </span>
        <h3 class="m-0 mb-1.5 font-display font-semibold text-[17px] text-gray-900">{s.nombre}</h3>
        <p class="m-0 mb-4 text-[13px] leading-normal text-gray-500">{s.descripcion}</p>
        <div class="mt-auto flex flex-col gap-2">
          {s.modalidades.map((m) => (
            <div class="flex items-center justify-between px-3 py-2 rounded-[10px] bg-gray-50 border border-gray-100">
              <span class="text-xs font-medium text-gray-600">{modalidadLabel[m.tipo] ?? m.tipo}</span>
              <span class="text-sm font-bold font-display text-sn-violet">{formatARS(m.precio)}</span>
            </div>
          ))}
          {s.nota && <span class="text-[11px] text-gray-400 pl-0.5">{s.nota}</span>}
        </div>
      </div>
    ))}
  </div>
</section>
