---
import packs from '../../content/packs.json';
import type { Pack } from '../../content/_types';
import PackCard from '../packs/PackCard.astro';

const packsTipados = packs as Pack[];
const destacados = packsTipados.slice(0, 4);
---
<section class="bg-violet-mid px-6 py-12 md:py-16">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-8">
      <div class="text-xs text-cream/50 uppercase tracking-widest">Capa 2 · Packs por necesidad</div>
      <h2 class="text-2xl md:text-3xl font-bold text-cream mt-1">¿Tenés un dolor específico?</h2>
      <p class="text-cream/65 text-sm mt-2">Pago único · sesiones limitadas · resolución de un dolor o objetivo puntual</p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
      {destacados.map((pack) => <PackCard pack={pack} />)}
    </div>

    <div class="text-center text-xs text-cream/60 mt-6">
      + 7 packs más ·
      <a href="/packs" class="text-accent-mint underline">ver todos los packs →</a>
    </div>
  </div>
</section>
