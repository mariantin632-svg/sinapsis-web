---
import obras from '../../content/obras-sociales.json';
import type { ObraSocial } from '../../content/_types';

const obrasTipadas = obras as ObraSocial[];
---
<section class="bg-cream-bg px-6 py-12 md:py-16">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-8">
      <div class="text-xs text-gray-500 uppercase tracking-widest">Obras sociales</div>
      <h2 class="text-2xl md:text-3xl font-bold text-violet-deep mt-1">Trabajamos con las principales</h2>
    </div>

    <div class="flex flex-wrap gap-2 justify-center">
      {obrasTipadas.map((o) => (
        <div class="bg-white px-5 py-3 rounded text-sm text-gray-600 border border-gray-200">
          {o.nombre}
        </div>
      ))}
    </div>

    <div class="text-center mt-6 text-xs">
      <a href="/obras-sociales" class="text-accent-mint underline">Ver lista completa y cómo presentar orden →</a>
    </div>
  </div>
</section>
