---
import obras from '../../content/obras-sociales.json';
import type { ObraSocial } from '../../content/_types';

const obrasTipadas = obras as ObraSocial[];
---
<section id="obras" class="bg-white border-y border-gray-100 mt-14">
  <div class="max-w-[1200px] mx-auto px-6 py-[72px]">
    <div class="text-center mb-9">
      <p class="m-0 mb-2.5 text-xs font-semibold tracking-[1.5px] uppercase text-sn-sage-dark">Obras sociales</p>
      <h2 class="m-0 font-display font-semibold text-[clamp(1.6rem,3.2vw,2.1rem)] leading-[1.12] text-sn-violet">Trabajamos con las principales</h2>
    </div>
    <div class="flex flex-wrap justify-center gap-3 max-w-[900px] mx-auto">
      {obrasTipadas.map((o) => (
        <span class="text-sm font-medium text-gray-600 bg-gray-50 border border-gray-100 px-[18px] py-2.5 rounded-full">{o.nombre}</span>
      ))}
    </div>
    <div class="text-center mt-8">
      <a href="/obras-sociales" class="inline-flex items-center gap-2 text-sm font-semibold text-sn-violet hover:text-sn-violet-light transition">Ver lista completa y cómo presentar orden <span class="text-base">→</span></a>
    </div>
  </div>
</section>
