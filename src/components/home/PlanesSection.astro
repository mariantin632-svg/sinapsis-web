---
import planes from '../../content/planes.json';
import type { Plan } from '../../content/_types';
import PlanCard from '../planes/PlanCard.astro';
import DuracionToggle from '../planes/DuracionToggle.astro';

const planesTipados = (planes as Plan[]).sort((a, b) => a.orden - b.orden);
---
<section class="bg-white px-4 sm:px-6 py-10 md:py-14">
  <div class="max-w-7xl mx-auto bg-violet-deep rounded-[28px] px-6 py-10 md:px-10 md:py-12 shadow-card-hover">
    <div class="flex flex-col md:flex-row md:justify-between md:items-end gap-4 mb-8">
      <div>
        <div class="text-xs text-cream/50 uppercase tracking-widest">Planes & tratamientos</div>
        <h2 class="text-2xl md:text-3xl font-bold text-cream mt-1">Encontrá tu plan ideal</h2>
      </div>
      <DuracionToggle />
    </div>

    <div class="relative" data-carousel>
      <!-- Flechas -->
      <button
        type="button"
        data-carousel-prev
        aria-label="Plan anterior"
        class="hidden md:flex absolute -left-4 top-1/2 -translate-y-1/2 z-10 w-10 h-10 items-center justify-center rounded-full bg-cream text-violet-deep shadow-card-hover hover:bg-white transition disabled:opacity-30 disabled:cursor-not-allowed"
      >
        <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6" /></svg>
      </button>
      <button
        type="button"
        data-carousel-next
        aria-label="Plan siguiente"
        class="hidden md:flex absolute -right-4 top-1/2 -translate-y-1/2 z-10 w-10 h-10 items-center justify-center rounded-full bg-cream text-violet-deep shadow-card-hover hover:bg-white transition disabled:opacity-30 disabled:cursor-not-allowed"
      >
        <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6" /></svg>
      </button>

      <!-- Track -->
      <div
        data-carousel-track
        class="flex gap-4 overflow-x-auto scroll-smooth snap-x snap-mandatory pb-2 carousel-track"
      >
        {planesTipados.map((plan) => (
          <div class="snap-start shrink-0 flex w-[85%] sm:w-[calc(50%-0.5rem)] lg:w-[calc(33.333%-0.667rem)]">
            <PlanCard plan={plan} />
          </div>
        ))}
      </div>
    </div>

    <div class="text-center text-xs text-cream/60 mt-6">
      Pago único al activar · transferencia, efectivo o tarjeta (10% de recargo en 1 pago) ·
      <a href="/planes" class="text-accent-mint underline">comparar planes en detalle →</a>
    </div>
  </div>
</section>

<style>
  .carousel-track { scrollbar-width: none; -ms-overflow-style: none; }
  .carousel-track::-webkit-scrollbar { display: none; }
</style>

<script>
  function initCarousel(root: HTMLElement) {
    const track = root.querySelector<HTMLElement>('[data-carousel-track]');
    const prev = root.querySelector<HTMLButtonElement>('[data-carousel-prev]');
    const next = root.querySelector<HTMLButtonElement>('[data-carousel-next]');
    if (!track) return;

    const step = () => {
      const first = track.firstElementChild as HTMLElement | null;
      if (!first) return track.clientWidth;
      const gap = parseFloat(getComputedStyle(track).columnGap || '16') || 16;
      return first.getBoundingClientRect().width + gap;
    };

    const update = () => {
      const maxScroll = track.scrollWidth - track.clientWidth - 1;
      if (prev) prev.disabled = track.scrollLeft <= 0;
      if (next) next.disabled = track.scrollLeft >= maxScroll;
    };

    prev?.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }));
    next?.addEventListener('click', () => track.scrollBy({ left: step(), behavior: 'smooth' }));
    track.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    update();
  }

  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach(initCarousel);
</script>
