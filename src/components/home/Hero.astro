---
import sitio from '../../content/sitio.json';
import CtaWhatsApp from '../shared/CtaWhatsApp.astro';
---
<section class="bg-white px-6 py-12 md:py-20">
  <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-10 items-center">
    <div>
      <div class="text-xs text-gray-500 uppercase tracking-widest">{sitio.tagline}</div>
      <h1 class="text-3xl md:text-5xl font-bold mt-3 leading-tight text-violet-deep">
        Tu cuerpo en las mejores manos.<br />
        <span class="text-sinapsis-purple">Cuidate todo el año.</span>
      </h1>
      <p class="text-base text-gray-600 mt-4 leading-relaxed">
        Suscripciones mensuales, packs por dolor específico o sesiones sueltas. José C. Paz · presencial y online.
      </p>
      <div class="flex flex-wrap gap-3 mt-6">
        <a href="/planes" class="bg-sinapsis-purple text-white px-5 py-2.5 rounded-pill text-sm font-bold hover:opacity-90 transition">
          Ver planes →
        </a>
        <CtaWhatsApp text="Consultar por WhatsApp" message="Hola! Quería hacer una consulta inicial." variant="outline-dark" />
      </div>
      <div class="mt-6 flex items-center gap-2 text-sm text-gray-600">
        <span class="text-accent-yellow text-base">★★★★★</span>
        <span>{sitio.google_reviews.rating} / 5 · {sitio.google_reviews.count} reseñas Google</span>
      </div>
    </div>
    <div class="rounded-card h-60 md:h-80 relative overflow-hidden bg-violet-deep flex items-center justify-center">
      <!-- PLACEHOLDER mientras llegan las fotos del centro -->
      <div class="absolute inset-0 opacity-30" style="background: radial-gradient(circle at 30% 30%, var(--color-sinapsis-purple) 0%, transparent 60%), radial-gradient(circle at 70% 70%, var(--color-accent-mint) 0%, transparent 50%);"></div>
      <div class="relative text-center px-6">
        <img src="/logo-sinapsis.jpg" alt="Sinapsis" class="h-12 md:h-14 w-auto mx-auto rounded-md shadow-lg" />
        <div class="text-cream/80 text-xs uppercase tracking-widest mt-4">José C. Paz</div>
      </div>
    </div>
  </div>
</section>
