---
import sitio from '../../content/sitio.json';
import { buildWhatsAppUrl } from '../../lib/whatsapp';

const turnitoUrl = sitio.turnito?.hub ?? '#';
const whatsappUrl = buildWhatsAppUrl({
  phone: sitio.contacto.whatsapp,
  text: 'Hola! Quería hacer una consulta inicial.',
});
---
<section class="bg-white px-6 py-12 md:py-20">
  <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-10 items-center">
    <div>
      <div class="text-xs text-accent-mint uppercase tracking-widest font-semibold">Kinesiología · Osteopatía · Traumatología · Nutrición</div>
      <h1 class="text-3xl md:text-5xl font-bold mt-3 leading-tight text-violet-deep">
        Tu cuerpo en las<br />
        <span class="text-sinapsis-purple">mejores manos.</span>
      </h1>
      <p class="text-base text-gray-600 mt-4 leading-relaxed">
        No tratamos síntomas: buscamos el origen. Reservá con el profesional que necesitás,
        presencial u online, en José C. Paz.
      </p>
      <div class="flex flex-wrap gap-3 mt-6">
        <a href={turnitoUrl} target="_blank" rel="noopener" class="bg-sinapsis-purple text-white px-5 py-2.5 rounded-pill text-sm font-bold hover:opacity-90 transition">
          Agendar turno
        </a>
        <a href="/planes" class="border border-sinapsis-purple text-sinapsis-purple px-5 py-2.5 rounded-pill text-sm font-bold hover:bg-sinapsis-purple hover:text-white transition">
          Ver planes →
        </a>
        <a href={whatsappUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 border border-violet-deep/30 text-violet-deep px-5 py-2.5 rounded-pill text-sm font-bold hover:bg-violet-deep/5 transition">
          📱 Consultar
        </a>
      </div>
      <div class="mt-7 flex flex-wrap items-center gap-x-7 gap-y-2 text-sm text-gray-600">
        <span class="flex items-center gap-1.5">
          <span class="text-accent-yellow text-base">★</span>
          <b class="text-violet-deep">{sitio.google_reviews.rating}</b> · {sitio.google_reviews.count} reseñas
        </span>
        <span><b class="text-violet-deep">+600</b> pacientes</span>
        <span><b class="text-violet-deep">5+</b> años</span>
      </div>
    </div>
    <div class="rounded-card h-72 md:h-96 relative overflow-hidden bg-violet-deep">
      <img
        src="/equipo/presentacion-martin-niro.jpg"
        alt="Sinapsis — atención profesional en José C. Paz"
        class="w-full h-full object-cover object-top"
        loading="eager"
        onerror="this.style.display='none'"
      />
      <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(180deg, transparent 55%, rgba(26,14,61,.55) 100%);"></div>
    </div>
  </div>
</section>
