---
import { existsSync } from 'node:fs';
import path from 'node:path';
import equipo from '../../content/equipo.json';
import sitio from '../../content/sitio.json';
import type { Profesional } from '../../content/_types';
import { buildWhatsAppUrl } from '../../lib/whatsapp';
import Icon from '../shared/Icon.astro';

const equipoTipado = equipo as Profesional[];

const miembros = equipoTipado.map((prof) => {
  const chips = [...(prof.modalidades ?? [])];
  if (prof.destacado_label) chips.push(prof.destacado_label);
  return {
    ...prof,
    iniciales: `${prof.nombre.charAt(0)}${prof.apellido.charAt(0)}`,
    chips,
    // Si no hay foto en public/ no rendereamos el <img>: quedan las iniciales
    // (Dante va sin foto a propósito) y evitamos un 404 en consola.
    fotoExiste: existsSync(path.join(process.cwd(), 'public', prof.foto)),
    turnitoUrl: prof.turnito || sitio.turnito?.hub || '#',
    whatsappUrl: buildWhatsAppUrl({
      phone: sitio.contacto.whatsapp,
      text: `Hola! Quería consultar un turno con ${prof.nombre} ${prof.apellido}.`,
    }),
  };
});
---
<section id="equipo" class="max-w-[1200px] mx-auto px-6 pt-24 pb-10">
  <div class="mb-11 max-w-[640px]">
    <p class="m-0 mb-2.5 text-xs font-semibold tracking-[1.5px] uppercase text-sn-sage-dark">Equipo</p>
    <h2 class="m-0 mb-2.5 font-display font-semibold text-[clamp(1.9rem,4vw,2.6rem)] leading-[1.12] tracking-[-0.02em] text-sn-violet">Elegí con quién te atendés</h2>
    <p class="m-0 text-[15px] text-gray-500">Cada profesional, su propia agenda. Reservá online o escribinos.</p>
  </div>
  <div class="grid grid-cols-[repeat(auto-fill,minmax(260px,1fr))] gap-[22px]">
    {miembros.map((m) => (
      <div class="bg-white rounded-2xl overflow-hidden shadow-[0_2px_8px_rgba(48,22,109,0.08)] border border-gray-100 flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_32px_rgba(48,22,109,0.16)]">
        <div class="relative h-[230px] bg-gradient-to-br from-sn-violet to-sn-violet-light flex items-center justify-center overflow-hidden">
          <span class="absolute font-display font-bold text-[52px] text-white/20 tracking-[2px]">{m.iniciales}</span>
          {m.fotoExiste && (
            <img
              src={m.foto}
              alt={`${m.nombre} ${m.apellido}`}
              class="absolute inset-0 w-full h-full object-cover object-top"
              loading="lazy"
            />
          )}
        </div>
        <div class="p-5 flex flex-col flex-1">
          <h3 class="m-0 mb-[3px] font-display font-semibold text-[17px] text-gray-900">{m.nombre} {m.apellido}</h3>
          <p class="m-0 mb-3 text-xs font-semibold text-sn-sage-dark">{m.especialidades.join(' · ')}</p>
          {m.chips.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mb-3">
              {m.chips.map((c) => (
                <span class="text-[11px] font-medium text-gray-600 bg-[#f1f0f7] px-2.5 py-1 rounded-full">{c}</span>
              ))}
            </div>
          )}
          <p class="m-0 mb-4 text-[13px] leading-normal text-gray-500">{m.bio_corta}</p>
          <div class="mt-auto flex gap-2">
            <a
              href={m.turnitoUrl}
              target="_blank"
              rel="noopener"
              class="flex-1 text-center py-2.5 rounded-[10px] bg-gradient-to-br from-sn-violet to-sn-violet-light text-white font-semibold text-[13px] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_6px_18px_rgba(48,22,109,0.25)]"
            >Reservar</a>
            <a
              href={m.whatsappUrl}
              target="_blank"
              rel="noopener"
              aria-label={`Consultar por WhatsApp a ${m.nombre} ${m.apellido}`}
              class="w-[42px] flex items-center justify-center rounded-[10px] border-[1.5px] border-gray-200 text-sn-violet text-[17px] hover:border-sn-sage hover:bg-[#f4faf8] transition"
            ><Icon name="whatsapp" /></a>
          </div>
        </div>
      </div>
    ))}
  </div>
  <div class="text-center mt-9">
    <a href="/equipo" class="inline-flex items-center gap-2 text-sm font-semibold text-sn-violet hover:text-sn-violet-light transition">Ver perfil completo del equipo <span class="text-base">→</span></a>
  </div>
</section>
