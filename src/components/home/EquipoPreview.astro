---
import equipo from '../../content/equipo.json';
import type { Profesional } from '../../content/_types';
import EquipoCard from '../shared/EquipoCard.astro';

const equipoTipado = equipo as Profesional[];
---
<section class="bg-cream-bg px-6 py-12 md:py-16">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-8">
      <div class="text-xs text-gray-500 uppercase tracking-widest">Equipo</div>
      <h2 class="text-2xl md:text-3xl font-bold text-violet-deep mt-1">Elegí con quién te atendés</h2>
      <p class="text-gray-600 text-sm mt-2">Cada profesional, su propia agenda. Reservá online o escribinos.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {equipoTipado.map((prof) => <EquipoCard profesional={prof} />)}
    </div>

    <div class="text-center mt-6 text-xs">
      <a href="/equipo" class="text-sinapsis-purple underline font-semibold">Ver perfil completo del equipo →</a>
    </div>
  </div>
</section>
