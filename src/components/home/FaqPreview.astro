---
import faq from '../../content/faq.json';
import type { FaqItem } from '../../content/_types';
import FaqAccordion from '../shared/FaqAccordion.astro';

const items = (faq as FaqItem[]).slice(0, 5);
---
<section class="bg-white px-6 py-12 md:py-16">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-8">
      <div class="text-xs text-gray-500 uppercase tracking-widest">Preguntas frecuentes</div>
    </div>

    <FaqAccordion items={items} />

    <div class="text-center mt-6 text-xs">
      <a href="/faq" class="text-accent-mint underline">Ver todas las preguntas →</a>
    </div>
  </div>
</section>
