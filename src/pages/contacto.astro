---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaWhatsApp from '../components/shared/CtaWhatsApp.astro';
import sitio from '../content/sitio.json';

const direccionEncoded = encodeURIComponent(`${sitio.direccion.calle}, ${sitio.direccion.ciudad}, ${sitio.direccion.provincia}`);
const mapSrc = `https://www.google.com/maps?q=${direccionEncoded}&output=embed`;
---
<BaseLayout title="Contacto · Sinapsis">
  <section class="bg-white px-6 py-12">
    <div class="max-w-3xl mx-auto text-center">
      <div class="text-xs text-gray-500 uppercase tracking-widest">Contacto</div>
      <h1 class="text-3xl md:text-4xl font-bold text-violet-deep mt-3">Vení a Sinapsis</h1>
    </div>
  </section>

  <section class="bg-cream-bg px-6 py-10">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-8">
      <div class="space-y-4">
        <div>
          <div class="text-xs text-gray-500 uppercase tracking-wider">Dirección</div>
          <div class="text-violet-deep font-semibold text-lg">{sitio.direccion.calle}</div>
          <div class="text-sm text-gray-600">{sitio.direccion.ciudad} · {sitio.direccion.provincia}</div>
        </div>

        <div>
          <div class="text-xs text-gray-500 uppercase tracking-wider">Horarios</div>
          <div class="text-sm text-gray-700 mt-1 space-y-1">
            <div><strong>Lunes a viernes:</strong> {sitio.horarios.lunes_viernes}</div>
            <div><strong>Sábado:</strong> {sitio.horarios.sabado}</div>
            <div><strong>Domingo:</strong> {sitio.horarios.domingo}</div>
          </div>
        </div>

        <div>
          <div class="text-xs text-gray-500 uppercase tracking-wider">WhatsApp</div>
          <div class="text-violet-deep font-semibold">{sitio.contacto.whatsapp_display}</div>
          <div class="mt-3">
            <CtaWhatsApp text="Escribinos" message="Hola! Quería hacer una consulta." size="md" />
          </div>
        </div>
      </div>

      <div class="rounded-card overflow-hidden h-80 bg-white">
        <iframe src={mapSrc} width="100%" height="100%" style="border:0;" loading="lazy" title="Mapa Sinapsis"></iframe>
      </div>
    </div>
  </section>
</BaseLayout>
