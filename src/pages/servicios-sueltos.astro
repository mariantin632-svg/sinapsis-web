---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaWhatsApp from '../components/shared/CtaWhatsApp.astro';
import { formatARS } from '../lib/precios';
import sueltos from '../content/servicios-sueltos.json';
import type { ServicioSuelto } from '../content/_types';

const servicios = sueltos as ServicioSuelto[];
---
<BaseLayout title="Servicios sueltos · Sinapsis">
  <section class="bg-white px-6 py-12">
    <div class="max-w-3xl mx-auto text-center">
      <div class="text-xs text-gray-500 uppercase tracking-widest">Servicios sueltos</div>
      <h1 class="text-3xl md:text-4xl font-bold text-violet-deep mt-3">Sesiones individuales</h1>
      <p class="text-gray-600 mt-3">Pagás solo lo que necesitás, cuando lo necesitás. Sin compromiso de plan.</p>
    </div>
  </section>

  <section class="bg-cream-bg px-6 py-12">
    <div class="max-w-3xl mx-auto space-y-3">
      {servicios.map((s) => (
        <article class="bg-white rounded-card p-5 shadow-card">
          <h2 class="font-bold text-violet-deep">{s.nombre}</h2>
          {s.descripcion && <p class="text-sm text-gray-600 mt-1">{s.descripcion}</p>}
          <div class="mt-3 flex flex-wrap gap-x-6 gap-y-1 text-sm">
            {s.modalidades.map((m) => (
              <div class="text-gray-700">
                <span class="capitalize text-gray-500">{m.tipo}:</span>
                <span class="font-semibold ml-1">{m.precio === 0 ? 'a consultar' : formatARS(m.precio)}</span>
              </div>
            ))}
          </div>
          <div class="mt-4">
            <CtaWhatsApp
              text="Consultar"
              message={`Hola! Me interesa una sesión de ${s.nombre}.`}
              size="sm"
            />
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
