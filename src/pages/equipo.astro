---
import BaseLayout from '../layouts/BaseLayout.astro';
import equipoData from '../content/equipo.json';
import sitio from '../content/sitio.json';
import type { Profesional } from '../content/_types';
import { buildWhatsAppUrl } from '../lib/whatsapp';

const equipo = equipoData as Profesional[];
const turnitoHub = sitio.turnito?.hub ?? '#';
---
<BaseLayout title="Equipo · Sinapsis">
  <section class="bg-white px-6 py-12">
    <div class="max-w-3xl mx-auto text-center">
      <div class="text-xs text-gray-500 uppercase tracking-widest">Equipo</div>
      <h1 class="text-3xl md:text-4xl font-bold text-violet-deep mt-3">Nuestro equipo profesional</h1>
      <p class="text-gray-600 mt-3">Profesionales matriculados con formación en kinesiología, osteopatía y deporte.</p>
    </div>
  </section>

  <section class="bg-cream-bg px-6 py-12">
    <div class="max-w-5xl mx-auto space-y-6">
      {equipo.map((prof) => (
        <article id={prof.slug} class="bg-white rounded-card p-6 grid md:grid-cols-[120px_1fr] gap-5 items-start shadow-card">
          <div class="relative w-30 h-30">
            <div class="absolute inset-0 rounded-full bg-gradient-to-br from-sinapsis-purple to-accent-mint flex items-center justify-center text-white text-2xl font-bold">
              {prof.nombre.charAt(0)}{prof.apellido.charAt(0)}
            </div>
            <img src={prof.foto} alt={`${prof.nombre} ${prof.apellido}`} class="absolute inset-0 w-full h-full rounded-full object-cover" onerror="this.style.display='none'" />
          </div>
          <div>
            <h2 class="text-xl font-bold text-violet-deep">{prof.nombre} {prof.apellido}</h2>
            <div class="text-sm text-gray-500 mt-1">{prof.especialidades.join(' · ')}</div>
            {prof.matricula && !prof.matricula.includes('PLACEHOLDER') && (
              <div class="text-xs text-gray-400 mt-1">Matrícula: {prof.matricula}</div>
            )}
            <p class="text-sm text-gray-700 mt-3 leading-relaxed">
              {prof.bio_larga || prof.bio_corta}
            </p>
            {prof.formacion && prof.formacion.length > 0 && (
              <div class="mt-3">
                <div class="text-xs uppercase text-gray-500 tracking-wider mb-1">Formación</div>
                <ul class="text-sm text-gray-700 list-disc list-inside">
                  {prof.formacion.map((f) => <li>{f}</li>)}
                </ul>
              </div>
            )}
            <div class="flex flex-wrap gap-2 mt-4">
              <a
                href={prof.turnito || turnitoHub}
                target="_blank"
                rel="noopener"
                class="bg-accent-mint text-accent-mint-dark text-sm font-bold px-4 py-2 rounded-pill hover:opacity-90 transition"
              >
                Reservar turno
              </a>
              <a
                href={buildWhatsAppUrl({ phone: sitio.contacto.whatsapp, text: `Hola! Quería consultar un turno con ${prof.nombre} ${prof.apellido}.` })}
                target="_blank"
                rel="noopener"
                class="border border-sinapsis-purple text-sinapsis-purple text-sm font-bold px-4 py-2 rounded-pill hover:bg-sinapsis-purple hover:text-white transition"
              >
                Consultar
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="bg-white px-6 py-14">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-8">
        <div class="text-xs text-gray-500 uppercase tracking-widest">Conocé al equipo</div>
        <h2 class="text-2xl md:text-3xl font-bold text-violet-deep mt-2">Fotos de presentación</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <figure class="rounded-card overflow-hidden shadow-card bg-violet-deep">
          <img
            src="/equipo/presentacion-martin-niro.jpg"
            alt="Lic. Martín Niro — Kinesiología y Osteopatía"
            class="w-full h-auto block"
            loading="lazy"
          />
        </figure>
        <figure class="rounded-card overflow-hidden shadow-card bg-violet-deep">
          <img
            src="/equipo/presentacion-santiago-duhau.jpg"
            alt="Lic. Santiago Duhau — Kinesiología y Deporte"
            class="w-full h-auto block"
            loading="lazy"
          />
        </figure>
        <figure class="rounded-card overflow-hidden shadow-card bg-violet-deep">
          <img
            src="/equipo/presentacion-jimena-avalos.jpg"
            alt="Lic. Jimena Belén Avalos — Nutrición"
            class="w-full h-auto block"
            loading="lazy"
          />
        </figure>
      </div>
    </div>
  </section>
</BaseLayout>
