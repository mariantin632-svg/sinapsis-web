---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PacksFilterableGrid from '../../components/packs/PacksFilterableGrid.astro';
---
<BaseLayout title="Packs por necesidad · Sinapsis">
  <section class="bg-white px-6 py-12">
    <div class="max-w-3xl mx-auto text-center">
      <div class="text-xs text-gray-500 uppercase tracking-widest">Packs</div>
      <h1 class="text-3xl md:text-4xl font-bold text-violet-deep mt-3">¿Tenés un dolor específico?</h1>
      <p class="text-gray-600 mt-3">Pago único, sesiones limitadas, resultados puntuales. Elegí el pack que se adapta a vos.</p>
    </div>
  </section>

  <section class="bg-violet-deep px-6 py-12">
    <div class="max-w-7xl mx-auto">
      <PacksFilterableGrid />
    </div>
  </section>
</BaseLayout>
