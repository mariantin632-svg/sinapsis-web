---
import BaseLayout from '../layouts/BaseLayout.astro';
import MapaCorporal from '../components/tests/MapaCorporal.astro';
import QuizPlan from '../components/tests/QuizPlan.astro';
import RuletaEstiramientos from '../components/tests/RuletaEstiramientos.astro';
---
<BaseLayout title="Tests interactivos · Sinapsis" description="Probá nuestros tests: encontrá tu plan ideal, identificá tu dolor y llevate un estiramiento.">
  <section class="bg-white px-6 py-12">
    <div class="max-w-3xl mx-auto text-center">
      <div class="text-xs text-gray-500 uppercase tracking-widest">Interactivo</div>
      <h1 class="text-3xl md:text-4xl font-bold text-violet-deep mt-3">Probate</h1>
      <p class="text-gray-600 mt-3">Tres mini-tests para conocerte un poco más y encontrar lo que necesitás. Rápidos y sin compromiso.</p>
    </div>
  </section>

  <!-- Mapa corporal -->
  <section class="bg-violet-deep px-6 py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-8">
        <div class="text-xs text-cream/50 uppercase tracking-widest">Test 1</div>
        <h2 class="text-2xl md:text-3xl font-bold text-cream mt-1">¿Dónde te duele?</h2>
      </div>
      <MapaCorporal />
    </div>
  </section>

  <!-- Quiz de plan -->
  <section class="bg-violet-mid px-6 py-12 md:py-16">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-8">
        <div class="text-xs text-cream/50 uppercase tracking-widest">Test 2</div>
        <h2 class="text-2xl md:text-3xl font-bold text-cream mt-1">Descubrí tu plan ideal</h2>
        <p class="text-cream/60 text-sm mt-2">4 preguntas y te decimos cuál te queda mejor.</p>
      </div>
      <div class="bg-violet-deep/60 rounded-card p-6">
        <QuizPlan />
      </div>
    </div>
  </section>

  <!-- Ruleta -->
  <section class="bg-violet-deep px-6 py-12 md:py-16">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-8">
        <div class="text-xs text-cream/50 uppercase tracking-widest">Test 3</div>
        <h2 class="text-2xl md:text-3xl font-bold text-cream mt-1">Ruleta de estiramientos</h2>
      </div>
      <RuletaEstiramientos />
    </div>
  </section>
</BaseLayout>
