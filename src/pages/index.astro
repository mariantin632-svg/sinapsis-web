---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import ServiciosTurno from '../components/home/ServiciosTurno.astro';
import EquipoPreview from '../components/home/EquipoPreview.astro';
import EnfoqueCards from '../components/home/EnfoqueCards.astro';
import PlanesSection from '../components/home/PlanesSection.astro';
import QuizPlan from '../components/tests/QuizPlan.astro';
import TestimoniosSection from '../components/home/TestimoniosSection.astro';
// import GaleriaSection from '../components/home/GaleriaSection.astro'; // re-habilitar cuando haya fotos del centro en public/galeria/
import ObrasSocialesPreview from '../components/home/ObrasSocialesPreview.astro';
import FaqPreview from '../components/home/FaqPreview.astro';
import UbicacionSection from '../components/home/UbicacionSection.astro';
---
<BaseLayout title="Sinapsis · Kinesiología y Osteopatía · José C. Paz">
  <Hero />
  <ServiciosTurno />
  <EquipoPreview />
  <EnfoqueCards />
  <PlanesSection />

  <section class="bg-violet-deep px-6 py-12 md:py-16 border-t border-white/10">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-8">
        <div class="text-xs text-cream/50 uppercase tracking-widest">¿No sabés cuál elegir?</div>
        <h2 class="text-2xl md:text-3xl font-bold text-cream mt-1">Descubrí tu plan ideal</h2>
        <p class="text-cream/60 text-sm mt-2">4 preguntas y te decimos cuál te queda mejor.</p>
      </div>
      <div class="bg-violet-mid rounded-card p-6">
        <QuizPlan />
      </div>
    </div>
  </section>

  <TestimoniosSection />
  {/* <GaleriaSection /> */}
  <ObrasSocialesPreview />
  <FaqPreview />
  <UbicacionSection />
</BaseLayout>
